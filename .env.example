# Copy this file to `.env` for local notes.
# Put real production values in GitHub Actions secrets, not in the repository.

# Docker Hub / CI image publish
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=
DOCKERHUB_REPOSITORY=personal-porto
DOCKERHUB_API_REPOSITORY=personal-porto-api

# EC2 / SSH deploy target
EC2_HOST=
EC2_USER=ubuntu
EC2_PORT=22
EC2_SSH_KEY=
EC2_APP_DIR=/opt/teladan-porto
EC2_SERVER_NAME=muelsm.site
EC2_NGINX_CONF=/etc/nginx/sites-available/muelsm.site
EC2_BLUE_PORT=8081
EC2_GREEN_PORT=8082
EC2_API_PORT=3000

# Current frontend runtime
VITE_API_BASE_URL=
VITE_SITE_URL=https://muelsm.site
VITE_PORTFOLIO_CHAT_WEBHOOK_URL=https://oktaavsm.bccdev.id/n8n/webhook/portfolio-chat

# Admin CRUD / API
API_NODE_ENV=development
API_HOST=0.0.0.0
PORT=3000
API_BASE_URL=http://localhost:3000/api
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://muelsm.site
DB_WAIT_TIMEOUT_MS=30000

# Future database
POSTGRES_DB=teladan_portfolio
POSTGRES_USER=teladan_portfolio
POSTGRES_PASSWORD=teladan_portfolio
DATABASE_URL=postgresql://teladan_portfolio:teladan_portfolio@127.0.0.1:5433/teladan_portfolio?schema=public

# Future auth
JWT_SECRET=
SESSION_SECRET=replace-with-a-long-random-string
COOKIE_SECRET=replace-with-a-long-random-string
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password

# Future uploads / media
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=25
PUBLIC_UPLOAD_BASE_URL=/uploads

# GitHub production secrets for API deploy
PROD_POSTGRES_DB=teladan_portfolio
PROD_POSTGRES_USER=teladan_portfolio
PROD_POSTGRES_PASSWORD=
PROD_CORS_ORIGIN=https://muelsm.site,https://www.muelsm.site
PROD_COOKIE_SECRET=
PROD_SESSION_SECRET=
PROD_ADMIN_EMAIL=
PROD_ADMIN_PASSWORD=
PROD_SESSION_DAYS=7
PROD_MAX_UPLOAD_MB=25
PROD_PUBLIC_UPLOAD_BASE_URL=/uploads
RUN_PROD_SEED=false

# Optional object storage later
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Future email/notifications, optional
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
