# Copy this file to `.env` for local notes.
# Put real production values in GitHub Actions secrets, not in the repository.

# Docker Hub / CI image publish
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=
DOCKERHUB_REPOSITORY=teladan-porto

# EC2 / SSH deploy target
EC2_HOST=
EC2_USER=ubuntu
EC2_PORT=22
EC2_SSH_KEY=
EC2_APP_DIR=/opt/teladan-porto
EC2_SERVER_NAME=muelsm.site
EC2_NGINX_CONF=/etc/nginx/conf.d/teladan-porto.conf
EC2_BLUE_PORT=8081
EC2_GREEN_PORT=8082

# Current frontend runtime
VITE_API_BASE_URL=
VITE_SITE_URL=https://muelsm.site

# Future admin CRUD / API
API_NODE_ENV=production
PORT=3000
API_BASE_URL=https://muelsm.site/api
CORS_ORIGIN=https://muelsm.site

# Future database
POSTGRES_DB=teladan_portfolio
POSTGRES_USER=teladan_portfolio
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://teladan_portfolio:CHANGE_ME@postgres:5432/teladan_portfolio?schema=public

# Future auth
JWT_SECRET=
SESSION_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Future uploads / media
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=25
PUBLIC_UPLOAD_BASE_URL=https://muelsm.site/uploads

# Optional object storage later
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Future email/notifications, optional
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
